{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "khabar": {
    "color": {
      "brand": {
        "50":  { "$value": "#FFF5F5", "$type": "color", "$description": "Lightest brand tint — page wash" },
        "100": { "$value": "#FFCDD2", "$type": "color", "$description": "Light fill — tag backgrounds" },
        "200": { "$value": "#EF9A9A", "$type": "color", "$description": "Soft accent — disabled states" },
        "300": { "$value": "#E57373", "$type": "color", "$description": "Medium light red" },
        "400": { "$value": "#D75050", "$type": "color", "$description": "Hover on light surfaces" },
        "500": { "$value": "#C63030", "$type": "color", "$description": "Active state" },
        "600": { "$value": "#B71C1C", "$type": "color", "$description": "PRIMARY — masthead, CTA, breaking" },
        "700": { "$value": "#9E1414", "$type": "color", "$description": "Hover on brand-600" },
        "800": { "$value": "#851010", "$type": "color", "$description": "Pressed / deep accent" },
        "900": { "$value": "#6B0C0C", "$type": "color", "$description": "Dark masthead, extreme contrast" }
      },
      "ink": {
        "900": { "$value": "#0F1A2E", "$type": "color", "$description": "Primary text — headlines, body" },
        "700": { "$value": "#374151", "$type": "color", "$description": "Secondary body text" },
        "500": { "$value": "#6B7280", "$type": "color", "$description": "Timestamps, bylines, captions" },
        "300": { "$value": "#9CA3AF", "$type": "color", "$description": "Placeholder, disabled text" },
        "100": { "$value": "#E5E7EB", "$type": "color", "$description": "Dividers, borders" }
      },
      "surface": {
        "paper":        { "$value": "#FAFAF8", "$type": "color", "$description": "Page background — warm off-white" },
        "card":         { "$value": "#FFFFFF", "$type": "color", "$description": "Card background on paper" },
        "raised":       { "$value": "#F3F4F2", "$type": "color", "$description": "Sidebar, secondary areas" },
        "line":         { "$value": "#E5E7EB", "$type": "color", "$description": "Dividers, input borders" },
        "line-strong":  { "$value": "#D1D5DB", "$type": "color", "$description": "Table borders, strong dividers" }
      },
      "category": {
        "breaking":      { "$value": "#B71C1C", "$type": "color" },
        "politics":      { "$value": "#1A237E", "$type": "color" },
        "sports":        { "$value": "#E65100", "$type": "color" },
        "business":      { "$value": "#1B5E20", "$type": "color" },
        "entertainment": { "$value": "#6A1B9A", "$type": "color" },
        "technology":    { "$value": "#0277BD", "$type": "color" },
        "lifestyle":     { "$value": "#AD1457", "$type": "color" },
        "national":      { "$value": "#4E342E", "$type": "color" },
        "international": { "$value": "#00695C", "$type": "color" },
        "education":     { "$value": "#F57F17", "$type": "color" }
      },
      "semantic": {
        "success-600": { "$value": "#2E7D32", "$type": "color" },
        "success-100": { "$value": "#E8F5E9", "$type": "color" },
        "warning-600": { "$value": "#F57F17", "$type": "color" },
        "warning-100": { "$value": "#FFFDE7", "$type": "color" },
        "danger-600":  { "$value": "#B71C1C", "$type": "color" },
        "danger-100":  { "$value": "#FFCDD2", "$type": "color" },
        "info-600":    { "$value": "#0277BD", "$type": "color" },
        "info-100":    { "$value": "#E1F5FE", "$type": "color" }
      }
    },
    "font": {
      "devanagari": { "$value": "'Noto Sans Devanagari', sans-serif", "$type": "fontFamily" },
      "latin":      { "$value": "'Poppins', sans-serif", "$type": "fontFamily" },
      "body":       { "$value": "'Poppins', 'Noto Sans Devanagari', sans-serif", "$type": "fontFamily" },
      "mono":       { "$value": "'JetBrains Mono', 'Courier New', monospace", "$type": "fontFamily" }
    },
    "size": {
      "display-xl": { "$value": "4rem",      "$type": "dimension", "$description": "64px — homepage hero" },
      "display-lg": { "$value": "3rem",      "$type": "dimension", "$description": "48px — feature headline" },
      "display-md": { "$value": "2.25rem",   "$type": "dimension", "$description": "36px — section hero" },
      "heading-xl": { "$value": "1.75rem",   "$type": "dimension", "$description": "28px — article H1" },
      "heading-lg": { "$value": "1.375rem",  "$type": "dimension", "$description": "22px — H2, section title" },
      "heading-md": { "$value": "1.125rem",  "$type": "dimension", "$description": "18px — card headline" },
      "heading-sm": { "$value": "1rem",      "$type": "dimension", "$description": "16px — H4 subsection" },
      "body-lg":    { "$value": "1.125rem",  "$type": "dimension", "$description": "18px — long-read body" },
      "body-md":    { "$value": "1rem",      "$type": "dimension", "$description": "16px — standard body" },
      "body-sm":    { "$value": "0.875rem",  "$type": "dimension", "$description": "14px — excerpts, secondary" },
      "caption":    { "$value": "0.75rem",   "$type": "dimension", "$description": "12px — timestamps, captions" },
      "overline":   { "$value": "0.6875rem", "$type": "dimension", "$description": "11px — category labels" },
      "label":      { "$value": "0.8125rem", "$type": "dimension", "$description": "13px — button text, nav" }
    },
    "space": {
      "0":  { "$value": "0px",   "$type": "dimension" },
      "1":  { "$value": "4px",   "$type": "dimension" },
      "2":  { "$value": "8px",   "$type": "dimension" },
      "3":  { "$value": "12px",  "$type": "dimension" },
      "4":  { "$value": "16px",  "$type": "dimension" },
      "5":  { "$value": "20px",  "$type": "dimension" },
      "6":  { "$value": "24px",  "$type": "dimension" },
      "8":  { "$value": "32px",  "$type": "dimension" },
      "10": { "$value": "40px",  "$type": "dimension" },
      "12": { "$value": "48px",  "$type": "dimension" },
      "16": { "$value": "64px",  "$type": "dimension" },
      "20": { "$value": "80px",  "$type": "dimension" },
      "24": { "$value": "96px",  "$type": "dimension" },
      "32": { "$value": "128px", "$type": "dimension" },
      "40": { "$value": "160px", "$type": "dimension" }
    },
    "radius": {
      "none": { "$value": "0px",     "$type": "dimension" },
      "xs":   { "$value": "2px",     "$type": "dimension" },
      "sm":   { "$value": "4px",     "$type": "dimension", "$description": "Buttons, inputs, badges" },
      "md":   { "$value": "8px",     "$type": "dimension", "$description": "Dropdowns, tooltips" },
      "lg":   { "$value": "12px",    "$type": "dimension", "$description": "News cards, modals" },
      "xl":   { "$value": "16px",    "$type": "dimension", "$description": "Feature hero cards" },
      "full": { "$value": "9999px",  "$type": "dimension", "$description": "Avatars, circular chips" }
    },
    "shadow": {
      "none": { "$value": "none", "$type": "shadow" },
      "xs":   { "$value": "0 1px 2px rgba(15,26,46,0.06)", "$type": "shadow" },
      "sm":   { "$value": "0 1px 3px rgba(15,26,46,0.10), 0 1px 2px rgba(15,26,46,0.06)", "$type": "shadow" },
      "md":   { "$value": "0 4px 6px rgba(15,26,46,0.10), 0 2px 4px rgba(15,26,46,0.06)", "$type": "shadow" },
      "lg":   { "$value": "0 10px 15px rgba(15,26,46,0.10), 0 4px 6px rgba(15,26,46,0.05)", "$type": "shadow" },
      "xl":   { "$value": "0 20px 25px rgba(15,26,46,0.10), 0 8px 10px rgba(15,26,46,0.04)", "$type": "shadow" }
    },
    "motion": {
      "duration": {
        "xs":  { "$value": "80ms",  "$type": "duration" },
        "sm":  { "$value": "160ms", "$type": "duration" },
        "md":  { "$value": "240ms", "$type": "duration" },
        "lg":  { "$value": "480ms", "$type": "duration" },
        "xl":  { "$value": "720ms", "$type": "duration" }
      },
      "easing": {
        "out":     { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",    "$type": "cubicBezier" },
        "in-out":  { "$value": "cubic-bezier(0.45, 0, 0.55, 1)",   "$type": "cubicBezier" },
        "linear":  { "$value": "linear",                            "$type": "cubicBezier" },
        "in":      { "$value": "cubic-bezier(0.55, 0, 1, 0.45)",   "$type": "cubicBezier" }
      }
    },
    "breakpoint": {
      "sm":  { "$value": "640px",  "$type": "dimension" },
      "md":  { "$value": "768px",  "$type": "dimension" },
      "lg":  { "$value": "1024px", "$type": "dimension" },
      "xl":  { "$value": "1280px", "$type": "dimension" },
      "2xl": { "$value": "1536px", "$type": "dimension" }
    },
    "container": {
      "page":    { "$value": "1200px", "$type": "dimension" },
      "article": { "$value": "680px",  "$type": "dimension" },
      "narrow":  { "$value": "480px",  "$type": "dimension" }
    }
  }
}
